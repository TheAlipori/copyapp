---
import { verifySession } from '../lib/session';
import POSTicket from '../components/POSTicket';
import AppHeader from '../components/AppHeader.astro';
import '../styles/global.css';

const session = await verifySession(Astro.cookies);
if (!session) return Astro.redirect('/login');
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Venta — Copymax POS</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-gray-100">
    <AppHeader activePage="pos" username={session.username} role={session.role} />

    <main class="max-w-7xl mx-auto px-4 py-4" style="height: calc(100vh - 57px);">
      <POSTicket client:load />
    </main>
  </body>
</html>
